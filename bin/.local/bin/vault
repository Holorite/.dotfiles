#!/usr/bin/env bash
# vault — thin CLI over the git-synced work-vault (zk notebook).
#
# Holds only what zk has no native equivalent for: project-slug derivation, the
# `<!-- auto:content -->` MOC reindexing, git-sync, and the `find` body-resolver.
# The note-creation / search / relation / MOC-ensure verbs that used to live here
# are now zk aliases (`zk exploration|plan|task`, `zk find`, `zk related`, `zk
# moc`) in .zk/config.toml — the Claude slash commands and the vault-explorer
# agent call those directly. This CLI stays declarative for the rest: it owns the
# vault path, the slug, and the git-sync incantation.
#
# Layout (flat project dirs, indexed by zk):
#
#   index.md                                  top MOC → links projects + free notes
#   projects/<slug>/index.md                  per-project MOC → links its notes
#   projects/<slug>/<topic>.md                a note; kind is a `tags:` value
#                                             (exploration|plan|task), not a subdir
#   <any>.md (vault root)                     free-floating notes (indexed in top MOC)
#
# The vault dir comes from $WORK_VAULT_DIR (exported by zsh/conf.d/vault.zsh
# from work_vault_dir() in .utils.sh) — required. Created on work envs by
# install/work-vault/install.sh.
set -euo pipefail

die() { echo "vault: $*" >&2; exit 1; }

: "${WORK_VAULT_DIR:?not set — source zsh/conf.d/vault.zsh or run ./install.sh work-vault}"
VAULT="$WORK_VAULT_DIR"
[[ -d "$VAULT" ]] || die "vault not found at $VAULT (run ./install.sh work-vault)"

# Lowercase + collapse every non-alnum run to a single dash, trimming edges.
# Turns a remote name or branch segment into a filesystem-safe slug
# (cfgs_for_cost_model -> cfgs-for-cost-model).
slugify() {
    tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//'
}

# Normalize a string for substring matching in `find`: lowercase, collapse every
# non-alnum run to a single space, trim edges. Unlike slugify (dash-joined, for
# filesystem slugs) this is space-joined so a query is a clean substring of a
# title — `zk mcp`, `zk-mcp`, and `ZK MCP` all normalize to `zk mcp`.
norm_match() {
    tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/ /g; s/^ +//; s/ +$//'
}

# Branch names that name the repo, not the work: on these we slug by the git
# remote (the old behavior). Any other branch is a feature/dev branch whose
# name *is* the project, so we slug by it instead.
TRUNK_BRANCHES="main master dev develop"

# Derive a stable project slug from a directory (default: cwd).
#   - in a git repo on a trunk branch -> the remote repo name (else toplevel dir)
#   - in a git repo on a feature branch -> the branch's last segment, slugified
#     (dev/juliray/cfgs_for_cost_model -> cfgs-for-cost-model), so distinct
#     branches of one shared remote land in distinct project dirs
#   - not a repo -> the toplevel dir name
# Detached HEAD (abbrev-ref == "HEAD") is treated as trunk: there's no branch
# name to key on, so fall back to the remote/dir.
cmd_slug() {
    local dir="${1:-$PWD}"
    [[ -d "$dir" ]] || die "not a directory: $dir"
    local toplevel
    if ! toplevel="$(git -C "$dir" rev-parse --show-toplevel 2>/dev/null)"; then
        echo "${dir##*/}" | slugify
        return
    fi

    local branch
    branch="$(git -C "$dir" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
    if [[ -n "$branch" && "$branch" != HEAD && " $TRUNK_BRANCHES " != *" $branch "* ]]; then
        # Feature branch: the branch's last segment is the project.
        echo "${branch##*/}" | slugify
        return
    fi

    # Trunk (or detached/unnamed): key on the remote repo name, else the dir.
    local raw
    if raw="$(git -C "$dir" config --get remote.origin.url 2>/dev/null)" && [[ -n "$raw" ]]; then
        raw="${raw##*/}"
        raw="${raw%.git}"
    else
        raw="${toplevel##*/}"
    fi
    echo "$raw" | slugify
}

cmd_dir() {
    echo "$VAULT"
}

# Rewrite the marker-bounded region named NAME in FILE with CONTENT (read from
# stdin). The region is the text strictly between `<!-- auto:NAME -->` and
# `<!-- /auto:NAME -->`. Everything outside the markers is preserved verbatim;
# a file without the markers is left unchanged (every MOC/index is seeded from a
# template that already contains them).
replace_region() {
    local file="$1" name="$2"
    local content; content="$(cat)"
    local tmp; tmp="$(mktemp)"
    awk -v name="$name" -v content="$content" '
        BEGIN { mopen="<!-- auto:" name " -->"; mclose="<!-- /auto:" name " -->" }
        skipping {
            if ($0 == mclose) { print mopen; if (content != "") print content; print mclose; skipping=0 }
            next
        }
        $0 == mopen { skipping=1; next }
        { print }
    ' "$file" > "$tmp"
    mv "$tmp" "$file"
}

# Emit a `## <heading>\n<body>` block (no trailing newlines, so command
# substitution doesn't eat them), or nothing if body is empty. Callers gather
# non-empty sections into an array and join them with the markdown blank-line
# separator before handing off to replace_region.
section() {
    local heading="$1" body="$2"
    [[ -n "$body" ]] || return 0
    printf '## %s\n%s' "$heading" "$body"
}

# Join the remaining args with a blank line between each. Used to glue
# `section` outputs together; an empty arg is dropped so absent sections don't
# leave double-blank gaps.
join_sections() {
    local sep=$'\n\n' out="" s
    for s in "$@"; do
        [[ -n "$s" ]] || continue
        [[ -z "$out" ]] && out="$s" || out+="$sep$s"
    done
    printf '%s' "$out"
}

# Ordered list of sectioned tags driving every MOC layout. Headings are the
# pluralized capitalized tag; tasks use `render_tasks` (checkbox + date + opt
# priority + sub-tasks/tracker), everything else uses `bullets-short`. The same
# list is exported as $SECTIONED_TAGS so the `zk bullets-untagged` alias's
# NOT-filter stays in sync.
SECTIONS=(task note exploration plan)

# Heading title for a sectioned tag — plain English pluralization, no inflection
# library. Add an entry here when adding a tag to SECTIONS.
section_heading() {
    case "$1" in
        task) echo Tasks ;;
        note) echo Notes ;;
        exploration) echo Explorations ;;
        plan) echo Plans ;;
        *) echo "${1^}s" ;;
    esac
}

# Render the bullet list for a sectioned tag scoped to a path (relative to
# vault). Tasks get the richer renderer (render_tasks: open sub-tasks, done/total
# tracker, project grouping at root); every other tag is the short renderer.
# Keeping this dispatch here lets content_for_scope's loop stay uniform.
render_section() {
    local tag="$1" path="$2"
    case "$tag" in
        task) render_tasks "$path" ;;
        *)    zk bullets-short "$path" --tag "$tag" --sort title 2>/dev/null ;;
    esac
}

# Map a task note's frontmatter `status` to a GFM checkbox glyph
# (todo/started/done → [ ]/[/]/[x]); an unknown status renders [?].
task_glyph() {
    case "$1" in
        todo)    echo '[ ]' ;;
        started) echo '[/]' ;;
        done)    echo '[x]' ;;
        *)       echo '[?]' ;;
    esac
}

# Project slug for a task's absolute path: the first path segment under
# <vault>/projects/.
slug_of() {
    local s="${1#"$VAULT"/projects/}"
    echo "${s%%/*}"
}

# Render the `## Tasks` body for a scope. Each task is a parent bullet plus its
# open sub-tasks (body checkboxes) and a done/total tracker.
#
#   $1 = scope path relative to vault ("." = root/whole-vault, "projects/<slug>")
#
# Root scope (path ".") differs in two ways: done parent tasks are hidden (the
# top index is an actionable dashboard), and tasks are grouped under a
# `### <slug>` heading carrying the project's done/total parent-task count. A
# per-project MOC lists every task (incl. done) flat, since it's already scoped
# to one project.
#
# Fields arrive NUL-delimited (so a record can't break on a stray newline) with
# US between fields (so multi-word titles / priorities like "VERY HIGH"
# survive). zk matches no notes for the path arg ".", so root scope passes NO
# path filter (whole notebook) rather than ".".
render_tasks() {
    local path="$1"
    local root=""; [[ "$path" == "." ]] && root="root"
    local US=$'\x1f'
    local -a scope=()
    [[ "$path" != "." ]] && scope=("$path")

    local out="" cur_slug=""
    local status abspath link title created priority
    while IFS="$US" read -r -d '' status abspath link title created priority; do
        # Dashboard (root) hides completed parent tasks.
        [[ "$root" == root && "$status" == "done" ]] && continue

        # Root: open a `### <slug>` heading when the project changes (--sort path
        # keeps a project contiguous). The tracker is the project's done/total
        # parent tasks — two quick zk counts, incl. the done tasks hidden above.
        if [[ "$root" == root ]]; then
            local slug; slug="$(slug_of "$abspath")"
            if [[ "$slug" != "$cur_slug" ]]; then
                cur_slug="$slug"
                local proj="projects/$slug" ptotal pdone
                ptotal="$(zk list -q --tag task "$proj" --format . 2>/dev/null | grep -c . || true)"
                pdone="$(zk list -q --tag task "$proj" --format '{{metadata.status}}' 2>/dev/null | grep -cx 'done' || true)"
                [[ -n "$out" ]] && out+=$'\n'
                out+="### [[projects/$slug/index|$slug]] ($pdone/$ptotal)"$'\n'
            fi
        fi

        # Sub-task tracker: count the note's body checkbox lines (any indent);
        # show "(done/total)" only when it has any.
        local sub_total sub_done tracker=""
        sub_total="$(grep -cE '^[[:space:]]*- \[[ xX/]\] ' "$abspath" 2>/dev/null || true)"
        sub_done="$(grep -cE '^[[:space:]]*- \[[xX]\] ' "$abspath" 2>/dev/null || true)"
        [[ "${sub_total:-0}" -gt 0 ]] && tracker=" ($sub_done/$sub_total)"

        local meta="$created"
        [[ -n "$priority" ]] && meta+=", $priority"
        out+="- $(task_glyph "$status") $link — $title ($meta)$tracker"$'\n'

        # The note's OPEN sub-tasks ([ ]/[/]), re-indented two spaces under the
        # parent so original nesting is preserved (done ones are in the tracker).
        local subs
        subs="$(grep -E '^[[:space:]]*- \[[ /]\] ' "$abspath" 2>/dev/null | sed 's/^/  /' || true)"
        [[ -n "$subs" ]] && out+="$subs"$'\n'
    done < <(zk list -q --tag task "${scope[@]}" --sort path \
        --format "{{metadata.status}}${US}{{abs-path}}${US}{{link}}${US}{{title}}${US}{{metadata.created}}${US}{{metadata.priority}}" \
        --delimiter0 2>/dev/null)

    printf '%s' "${out%$'\n'}"
}

# Build the full `<!-- auto:content -->` body for a path scope (`.` = vault
# root, `projects/<slug>` = one project). Walks SECTIONS in order, appends the
# Untagged catch-all from `bullets-untagged` (filtered by $SECTIONED_TAGS), and
# joins non-empty sections with a blank-line separator.
content_for_scope() {
    local path="$1" sections=() tag
    for tag in "${SECTIONS[@]}"; do
        sections+=("$(section "$(section_heading "$tag")" "$(render_section "$tag" "$path")")")
    done
    local untagged
    if [[ "$path" == "." ]]; then
        # Root scope: exclude `projects/` (per-project MOCs are surfaced via
        # `## Projects` instead, and per-project notes belong to their own MOC).
        untagged="$(zk bullets-untagged --exclude projects --sort title 2>/dev/null)"
    else
        # Per-project scope: the MOC itself (index.md) carries no kind tag —
        # exclude the exact path so it doesn't self-list.
        untagged="$(zk bullets-untagged "$path" --exclude "$path/index.md" --sort title 2>/dev/null)"
    fi
    sections+=("$(section Untagged "$untagged")")
    join_sections "${sections[@]}"
}

# Regenerate every `<!-- auto:content -->` block in the vault. Per-project MOCs
# scope queries to `projects/<slug>`; the top index also gets a `## Projects`
# index-of-MOCs prepended.
cmd_reindex() {
    cd "$VAULT" || die "cannot cd to vault: $VAULT"
    export SECTIONED_TAGS
    SECTIONED_TAGS="$(IFS=,; echo "${SECTIONS[*]}")"

    local -a slugs
    if [[ -d "$VAULT/projects" ]]; then
        while IFS= read -r d; do
            [[ -d "$d" ]] || continue
            local slug="${d##*/}"
            [[ "$slug" != ".gitkeep" ]] || continue
            slugs+=("$slug")
        done < <(find "$VAULT/projects" -mindepth 1 -maxdepth 1 -type d | sort)
    fi

    local slug
    for slug in "${slugs[@]}"; do
        local moc="$VAULT/projects/$slug/index.md"
        # Auto-seed missing MOCs — the slug exists on disk (we just discovered
        # the dir), so any absent index.md is a hole to fill, not an error.
        # Two lines: title + the marker pair that replace_region fills.
        [[ -f "$moc" ]] || printf '# MOC: %s\n\n<!-- auto:content -->\n<!-- /auto:content -->\n' "$slug" > "$moc"
        replace_region "$moc" "content" <<< "$(content_for_scope "projects/$slug")"
    done

    local index="$VAULT/index.md"
    if [[ -f "$index" ]]; then
        local projlist=""
        for slug in "${slugs[@]}"; do
            projlist+="- [[projects/$slug/index]]"$'\n'
        done
        projlist="${projlist%$'\n'}"
        local body
        body="$(join_sections "$(section Projects "$projlist")" "$(content_for_scope .)")"
        replace_region "$index" "content" <<< "$body"
    fi
}

# git add -A && commit && push, all best-effort and quiet on the no-op case.
cmd_sync() {
    local msg="${1:-vault: update}"
    # Refresh zk's index first so reindex's queries see freshly-written notes.
    zk index --no-input -q 2>/dev/null || true
    cmd_reindex
    git -C "$VAULT" add -A
    if git -C "$VAULT" diff --cached --quiet; then
        echo "vault: nothing to sync"
        return 0
    fi
    git -C "$VAULT" commit -q -m "$msg"
    if ! git -C "$VAULT" push -q 2>/dev/null; then
        echo "vault: committed locally but push failed (offline or no upstream?)" >&2
    fi
}

# Emit `path\ttitle` lines for notes whose title or basename contains the
# normalized query (see norm_match), most-recent first, MOC `index.md` rows
# dropped. The matcher behind `find`.
match_notes() {
    local q; q="$(printf '%s' "$1" | norm_match)"
    local path title base hay
    while IFS=$'\t' read -r path title; do
        [[ -n "$path" ]] || continue
        [[ "$path" == */index.md ]] && continue
        base="${path##*/}"
        hay="$(printf '%s %s' "$title" "$base" | norm_match)"
        [[ "$hay" == *"$q"* ]] && printf '%s\t%s\n' "$path" "$title"
    done < <(zk list --quiet --format "{{abs-path}}"$'\t'"{{title}}" --sort modified 2>/dev/null)
}

# Locate a note by TITLE or FILENAME — the `@`-mention resolver for agents.
# Deliberately NOT a full-text body search (zk's --match): bodies match far too
# much, so a common word would bury the note you meant. Matching is delegated to
# match_notes (normalized title+basename substring, MOC rows dropped). Behavior
# keys off the match count so the caller rarely has to branch:
#   0 matches  -> message on stderr, exit 1
#   1 match    -> print the note's full body to stdout, prefixed with a
#                 `# <abs-path>` header line, so the caller reads it inline with
#                 no extra Read round-trip (the whole point)
#   >1 matches -> print one `<abs-path>\t<title>` line per match (most-recent
#                 first) so the caller picks
# `--paths-only`/`-p` forces the path<TAB>title list even for a single match
# (lets scripted callers keep a uniform "0/1/>1 lines" branch).
cmd_find() {
    local paths_only=""
    [[ "${1:-}" == -p || "${1:-}" == --paths-only ]] && { paths_only=1; shift; }
    local query="$*"
    [[ -n "$query" ]] || die "find: need a query"

    local -a hits=()
    while IFS= read -r line; do
        [[ -n "$line" ]] && hits+=("$line")
    done < <(match_notes "$query")

    case "${#hits[@]}" in
        0) die "find: no title/filename match for \"$query\"" ;;
        1)
            if [[ -n "$paths_only" ]]; then
                printf '%s\n' "${hits[0]}"
            else
                printf '# %s\n\n' "${hits[0]%%$'\t'*}"
                cat "${hits[0]%%$'\t'*}"
            fi
            ;;
        *) printf '%s\n' "${hits[@]}" ;;
    esac
}

usage() {
    cat >&2 <<'EOF'
usage: vault <command> [args]
  dir                         print the vault directory (errors if absent)
  slug [dir]                  derive the project slug from a directory (default: cwd)
  find [-p] <query>           locate a note by title/filename: 1 match prints its
                              body (-p: path list), >1 prints path<TAB>title lines,
                              0 exits 1 (MOC index.md rows excluded)
  reindex                     regenerate all MOC + index link lists from the filesystem
  sync "<msg>"                reindex, then git add -A && commit && push (best-effort)

note creation / search / relations / MOC-ensure are zk aliases, not vault
subcommands: `zk exploration|plan|task <title>`, `zk find <query>`,
`zk related <path>`, `zk moc <slug>` (see .zk/config.toml). `vault find` differs
from `zk find`: it prints the body on a single match for inline reading.
EOF
    exit 2
}

case "${1:-}" in
    dir)     shift; cmd_dir "$@" ;;
    slug)    shift; cmd_slug "$@" ;;
    find)    shift; cmd_find "$@" ;;
    reindex) shift; cmd_reindex "$@" ;;
    sync)    shift; cmd_sync "$@" ;;
    ""|-h|--help) usage ;;
    *) die "unknown command: $1 (try --help)" ;;
esac
