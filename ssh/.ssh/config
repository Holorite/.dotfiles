Host *
    ForwardAgent yes
    ForwardX11 yes
    ForwardX11Trusted yes

# lemonade $BROWSER tunnel (see notes/improvements.md). The laptop runs
# `lemonade server` on 127.0.0.1:2489; re-forwarding the same port on every hop
# chains it back to the laptop, so `gh browse` opens a tab there at any depth in
# an ssh chain (laptop → work → another machine → ...). Excludes the github
# remotes: they deny port forwarding, which would print a warning on every push.
Host * !github.com !github.qualcomm.com !github.com-qcom-eng-650
    RemoteForward 2489 127.0.0.1:2489
    # ExitOnForwardFailure stays `no`: the tunnel binds 127.0.0.1:2489 on the
    # work host and *any* session there reaches it, so only one session needs to
    # hold the forward — the rest piggyback. `yes` would make a second concurrent
    # session (or a chained hop where 2489 is already bound) refuse to start.
    ExitOnForwardFailure no
    # Detect a dead link in ~45s (15×3) instead of ~90s. Shortens the window
    # where a stale session's sshd still holds 2489 and blocks a reconnect's
    # RemoteForward from binding — the "dead tunnel until the zombie is reaped"
    # case. Faster teardown here only frees the port sooner when the path later
    # recovers (laptop sleep/wake); a truly dead path still waits on the server's
    # own ClientAliveInterval / TCP timeout, which client config can't shorten.
    ServerAliveInterval 15
    ServerAliveCountMax 3

Host github.com-Holorite
    HostName github.com
    User git
    IdentityFile ~/.ssh/github_personal_private_key
    IdentitiesOnly yes
    ForwardX11 no
    
Host github.com
    HostName github.com
    User git
    ForwardX11 no


Host github.qualcomm.com
    HostName github.qualcomm.com
    User git
    ForwardX11 no
