Host *
    ForwardAgent yes
    ForwardX11 yes
    ForwardX11Trusted yes

# lemonade $BROWSER tunnel (see notes/improvements.md). The laptop runs
# `lemonade server` on 127.0.0.1:2489; re-forwarding the same port on every hop
# chains it back to the laptop, so `gh browse` opens a tab there at any depth in
# an ssh chain (laptop → work → another machine → ...). Excludes the github
# remotes: they deny port forwarding, which would print a warning on every push.
Host * !github.com !github.qualcomm.com !github.com-qcom-eng-650
    RemoteForward 2489 127.0.0.1:2489
    ExitOnForwardFailure no
    ServerAliveInterval 30
    ServerAliveCountMax 3

Host github.com-qcom-eng-650
    HostName github.com
    User git
    ForwardX11 no

Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/github_personal_private_key
    IdentitiesOnly yes
    ForwardX11 no

Host github.qualcomm.com
    HostName github.qualcomm.com
    User git
    ForwardX11 no
